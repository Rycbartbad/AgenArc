{
  "version": "1.0.0",
  "entryPoint": "trigger_1",
  "metadata": {
    "name": "router_agent",
    "description": "路由 Agent - 展示条件分支功能"
  },
  "nodes": [
    {
      "id": "trigger_1",
      "type": "Trigger",
      "label": "开始"
    },
    {
      "id": "llm_1",
      "type": "LLM_Task",
      "label": "处理请求",
      "description": "LLM 处理用户输入",
      "inputs": [
        {"name": "prompt", "type": "string"},
        {"name": "context", "type": "object", "default": null}
      ],
      "outputs": [
        {"name": "response", "type": "string"},
        {"name": "usage", "type": "object"}
      ],
      "config": {
        "model": "deepseek-chat",
        "temperature": 0.7,
        "system_prompt": "You are a helpful assistant. Keep responses brief."
      }
    },
    {
      "id": "router_1",
      "type": "Router",
      "label": "检查结束",
      "description": "检查是否结束对话",
      "inputs": [
        {"name": "input", "type": "any"}
      ],
      "outputs": [
        {"name": "output_A", "type": "any"},
        {"name": "output_B", "type": "any"}
      ],
      "config": {
        "conditions": [
          {
            "ref": "input",
            "operator": "contains",
            "value": "quit",
            "output": "B"
          },
          {
            "ref": "input",
            "operator": "contains",
            "value": "bye",
            "output": "B"
          },
          {
            "ref": "input",
            "operator": "contains",
            "value": "goodbye",
            "output": "B"
          }
        ],
        "default": "A"
      }
    },
    {
      "id": "log_goodbye",
      "type": "Log",
      "label": "结束语",
      "inputs": [
        {"name": "message", "type": "string", "default": "Goodbye! Have a great day!"}
      ]
    },
    {
      "id": "log_continue",
      "type": "Log",
      "label": "继续",
      "inputs": [
        {"name": "message", "type": "string", "default": "Response received."}
      ]
    }
  ],
  "edges": [
    {
      "source": "trigger_1",
      "sourcePort": "payload",
      "target": "llm_1",
      "targetPort": "prompt"
    },
    {
      "source": "llm_1",
      "sourcePort": "response",
      "target": "router_1",
      "targetPort": "input"
    },
    {
      "source": "router_1",
      "sourcePort": "output_A",
      "target": "log_continue",
      "targetPort": "message"
    },
    {
      "source": "router_1",
      "sourcePort": "output_B",
      "target": "log_goodbye",
      "targetPort": "message"
    }
  ]
}
