{
  "version": "1.0.0",
  "entryPoint": "trigger_1",
  "metadata": {
    "name": "loop_agent",
    "description": "循环 Agent - 展示循环控制结构"
  },
  "nodes": [
    {
      "id": "trigger_1",
      "type": "Trigger",
      "label": "开始",
      "description": "工作流入口"
    },
    {
      "id": "log_1",
      "type": "Log",
      "label": "触发日志",
      "description": "输出触发信息",
      "inputs": [
        {"name": "message", "type": "string", "default": "Loop agent started"}
      ]
    },
    {
      "id": "llm_1",
      "type": "LLM_Task",
      "label": "批量处理",
      "description": "处理批量任务",
      "inputs": [
        {"name": "prompt", "type": "string"},
        {"name": "context", "type": "object", "default": null}
      ],
      "outputs": [
        {"name": "response", "type": "string"},
        {"name": "usage", "type": "object"}
      ],
      "config": {
        "model": "deepseek-chat",
        "temperature": 0.7,
        "system_prompt": "You process items in a list. Current item: {{context.current_item}}"
      }
    },
    {
      "id": "log_result",
      "type": "Log",
      "label": "结果",
      "inputs": [
        {"name": "message", "type": "string", "default": ""}
      ]
    }
  ],
  "edges": [
    {
      "source": "trigger_1",
      "sourcePort": "payload",
      "target": "log_1",
      "targetPort": "message"
    },
    {
      "source": "trigger_1",
      "sourcePort": "payload",
      "target": "llm_1",
      "targetPort": "prompt"
    },
    {
      "source": "llm_1",
      "sourcePort": "response",
      "target": "log_result",
      "targetPort": "message"
    }
  ]
}
