{
  "version": "1.0.0",
  "metadata": {
    "name": "LLM Example",
    "description": "Example demonstrating LLM_Task operator",
    "author": "AgenArc"
  },
  "entryPoint": "trigger_1",

  "nodes": [
    {
      "id": "trigger_1",
      "type": "Trigger",
      "label": "Start",
      "outputs": [
        {
          "name": "payload",
          "type": "any"
        }
      ],
      "config": {
        "source": "manual"
      }
    },
    {
      "id": "llm_task_1",
      "type": "LLM_Task",
      "label": "LLM Task",
      "inputs": [
        {
          "name": "prompt",
          "type": "string"
        }
      ],
      "outputs": [
        {
          "name": "response",
          "type": "string"
        },
        {
          "name": "usage",
          "type": "object"
        }
      ],
      "config": {
        "model": "gpt-4",
        "temperature": 0.7,
        "system_prompt": "You are a helpful assistant."
      }
    },
    {
      "id": "log_result",
      "type": "Log",
      "label": "Log Result",
      "inputs": [
        {
          "name": "message",
          "type": "string"
        },
        {
          "name": "data",
          "type": "any"
        }
      ]
    }
  ],

  "edges": [
    {
      "source": "trigger_1",
      "sourcePort": "payload",
      "target": "llm_task_1",
      "targetPort": "prompt"
    },
    {
      "source": "llm_task_1",
      "sourcePort": "response",
      "target": "log_result",
      "targetPort": "message"
    }
  ]
}
