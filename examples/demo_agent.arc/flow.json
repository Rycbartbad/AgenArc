{
  "version": "1.0.0",
  "entryPoint": "trigger_1",
  "metadata": {
    "name": "demo_agent",
    "description": "Demo agent with routing and context",
    "author": "AgenArc",
    "tags": ["demo", "router", "context"]
  },
  "nodes": [
    {
      "id": "trigger_1",
      "type": "Trigger",
      "label": "Start",
      "description": "Entry point",
      "inputs": [],
      "outputs": [
        {"name": "payload", "type": "any"}
      ]
    },
    {
      "id": "context_set",
      "type": "Context_Set",
      "label": "Set Context",
      "description": "Set agent context",
      "inputs": [
        {"name": "key", "type": "string"},
        {"name": "value", "type": "any"}
      ],
      "outputs": [
        {"name": "success", "type": "boolean"}
      ]
    },
    {
      "id": "llm_1",
      "type": "LLM_Task",
      "label": "Chat",
      "description": "Generate LLM response",
      "inputs": [
        {"name": "prompt", "type": "string"},
        {"name": "context", "type": "object", "default": null}
      ],
      "outputs": [
        {"name": "response", "type": "string"},
        {"name": "usage", "type": "object"}
      ],
      "config": {
        "model": "deepseek-chat",
        "temperature": 0.7,
        "system_prompt": "arc://prompts/system.pt"
      }
    },
    {
      "id": "router_1",
      "type": "Router",
      "label": "Route Response",
      "description": "Check if response is complete",
      "inputs": [
        {"name": "input", "type": "any"}
      ],
      "outputs": [
        {"name": "output_A", "type": "any", "description": "More help needed"},
        {"name": "output_B", "type": "any", "description": "Complete"}
      ],
      "config": {
        "conditions": [
          {
            "ref": "input",
            "operator": "contains",
            "value": "bye",
            "output": "B"
          },
          {
            "ref": "input",
            "operator": "contains",
            "value": "thank",
            "output": "B"
          }
        ],
        "default": "A"
      }
    },
    {
      "id": "log_response",
      "type": "Log",
      "label": "Output",
      "description": "Output the response",
      "inputs": [
        {"name": "message", "type": "string"},
        {"name": "data", "type": "any", "default": null}
      ],
      "outputs": [
        {"name": "message", "type": "string"},
        {"name": "data", "type": "any"}
      ]
    }
  ],
  "edges": [
    {"source": "trigger_1", "sourcePort": "payload", "target": "context_set", "targetPort": ""},
    {"source": "context_set", "sourcePort": "success", "target": "llm_1", "targetPort": ""},
    {"source": "trigger_1", "sourcePort": "payload", "target": "llm_1", "targetPort": "prompt"},
    {"source": "llm_1", "sourcePort": "response", "target": "router_1", "targetPort": "input"},
    {"source": "router_1", "sourcePort": "output_B", "target": "log_response", "targetPort": "message"},
    {"source": "llm_1", "sourcePort": "response", "target": "log_response", "targetPort": "message"}
  ]
}
